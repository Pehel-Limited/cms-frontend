{
  "name": "cms-frontend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:bank": "turbo dev --filter=@cms/bank-ops",
    "dev:cust": "turbo dev --filter=@cms/cust-portal",
    "build": "turbo build",
    "build:bank": "turbo build --filter=@cms/bank-ops",
    "build:cust": "turbo build --filter=@cms/cust-portal",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.1.1",
    "turbo": "^2.4.0"
  },
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
